/**
5. Longest Palindromic Substring
Solved
Medium
Topics
premium lock icon
Companies
Hint
Given a string s, return the longest palindromic substring in s.

 

Example 1:

Input: s = "babad"
Output: "bab"
Explanation: "aba" is also a valid answer.
Example 2:

Input: s = "cbbd"
Output: "bb"
 

Constraints:

1 <= s.length <= 1000
s consist of only digits and English letters.

**/

class Solution {
public:
    void check_pal(int l, int r, string &s, int &reslen, int &start) {

        while (l>=0 && (r < s.size()) && (s[l] == s[r])) {
            if ((r-l+1) > reslen) {
                reslen = r-l+1;
                start = l;
            }
            l -= 1;
            r +=1;
        }
    }
    string longestPalindrome(string s) {
        int l, r = 0;
        int reslen = 0;
        int start = 0;
        string res = "";

        for(int i=0; i<s.size(); i++) {
            l = i;
            r = i;

            check_pal(l, r, s, reslen, start);
            
            r = i+1;

            check_pal(l, r, s, reslen, start);
        }
        return s.substr(start, reslen); 
    }
};
